# --- Cargo & Build Artifacts ---
# Ignore the entire target directory where compiled files live
/target/
/debug/

# --- Rust Formatting & Debugging ---
# Backup files generated by rustfmt
**/*.rs.bk

# Debugging symbols for MSVC (Windows)
*.pdb

# --- Testing & Analysis ---
# Output data from cargo mutants
**/mutants.out

# --- Language Stats Cleanup ---
# Ignore dependency files to keep GitHub language stats at 100% Rust
*.d

# --- IDEs & Environments ---
# JetBrains / RustRover settings
.idea/

# Visual Studio Code settings
.vscode/

# --- OS Specific Files ---
.DS_Store
Thumbs.db
